rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // managed only via firebase-admin (seed script / console)
    }

    match /industrialSites/{id} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isValidCrowdVote();

      // A public visitor may cast exactly one "working fine" / "problem" vote per
      // request: only the four crowd-vote fields may change, and one of the two
      // counters must move by exactly +1. crowdFlagged can only be set to true by
      // the math (>=50 total votes, >80% "problem"), never cleared by a public
      // write — only an admin can revert it, via /admin/crowd-flags. Split into two
      // helpers because a single function is capped at 10 `let` bindings.
      function isValidCrowdVote() {
        return voteDeltaValid() && flagTransitionValid();
      }

      function voteDeltaValid() {
        let before = resource.data;
        let after = request.resource.data;
        let touchedOnly = after.diff(before).affectedKeys()
          .hasOnly(['votesFine', 'votesProblem', 'crowdFlagged', 'crowdFlaggedAt']);
        let fineDelta = after.get('votesFine', 0) - before.get('votesFine', 0);
        let problemDelta = after.get('votesProblem', 0) - before.get('votesProblem', 0);
        let exactlyOneVote = (fineDelta == 1 && problemDelta == 0) || (fineDelta == 0 && problemDelta == 1);
        return touchedOnly && exactlyOneVote;
      }

      function flagTransitionValid() {
        let before = resource.data;
        let after = request.resource.data;
        let total = after.get('votesFine', 0) + after.get('votesProblem', 0);
        let wasFlagged = before.get('crowdFlagged', false) == true;
        let afterFlagged = after.get('crowdFlagged', false) == true;
        let flagMathValid = afterFlagged == (total >= 50 && after.get('votesProblem', 0) * 100 > total * 80);
        return wasFlagged ? afterFlagged == true : flagMathValid;
      }
    }

    match /historicalAccidents/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /newsItems/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /govFeedPosts/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /misinfoItems/{id} {
      allow read: if true;
      allow create: if request.resource.data.status == 'review'
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() < 2000;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /citizenReports/{id} {
      allow read: if true;
      allow create: if request.resource.data.location is string
        && request.resource.data.location.size() > 0
        && request.resource.data.desc is string
        && request.resource.data.desc.size() > 0;
      allow update, delete: if isAdmin();
    }
  }
}
