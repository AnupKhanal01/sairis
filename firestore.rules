rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // managed only via firebase-admin (seed script / console)
    }

    match /industrialSites/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /historicalAccidents/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /newsItems/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /govFeedPosts/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /misinfoItems/{id} {
      allow read: if true;
      allow create: if request.resource.data.status == 'review'
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() < 2000;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /citizenReports/{id} {
      allow read: if true;
      allow create: if request.resource.data.location is string
        && request.resource.data.location.size() > 0
        && request.resource.data.desc is string
        && request.resource.data.desc.size() > 0;
      allow update, delete: if isAdmin();
    }
  }
}
